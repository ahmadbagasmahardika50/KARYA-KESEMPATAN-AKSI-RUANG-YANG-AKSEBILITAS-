<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Profil Perusahaan - KARYA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Lexend', sans-serif; }</style>
</head>
<body class="bg-gray-50">
    <nav class="bg-white shadow px-6 py-3">
        <a href="perusahaan-dashboard.html" class="text-blue-600 hover:underline">← Kembali ke Dashboard</a>
    </nav>
    <div class="max-w-2xl mx-auto px-6 py-12">
        <div class="bg-white p-8 rounded-2xl shadow-md">
            <h1 class="text-2xl font-bold text-blue-900">Profil Perusahaan</h1>
            <form id="form" class="mt-6">
                <div class="mb-4">
                    <label class="block font-bold text-gray-700">Nama Perusahaan</label>
                    <input type="text" id="nama" class="w-full p-3 rounded-xl bg-gray-100" value="PT Maju Jaya">
                </div>
                <div class="mb-4">
                    <label class="block font-bold text-gray-700">Email</label>
                    <input type="email" id="email" class="w-full p-3 rounded-xl bg-gray-100" value="info@majujaya.com">
                </div>
                <div class="mb-4">
                    <label class="block font-bold text-gray-700">Telepon</label>
                    <input type="text" id="telepon" class="w-full p-3 rounded-xl bg-gray-100" value="0211234567">
                </div>
                <div class="mb-4">
                    <label class="block font-bold text-gray-700">Alamat</label>
                    <textarea id="alamat" class="w-full p-3 rounded-xl bg-gray-100">Jl. Sudirman No. 1, Jakarta</textarea>
                </div>
                <div class="mb-4">
                    <label class="block font-bold text-gray-700">Deskripsi Perusahaan</label>
                    <textarea id="deskripsi" class="w-full p-3 rounded-xl bg-gray-100">Perusahaan teknologi inklusif yang membuka peluang untuk semua.</textarea>
                </div>
                <button type="submit" class="w-full bg-blue-900 text-white py-3 rounded-xl font-bold hover:bg-blue-800">Simpan Perubahan</button>
            </form>
        </div>
    </div>
    <script>
        document.getElementById('form').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Profil perusahaan berhasil diperbarui!');
        });
    </script>
</body>
</html>
