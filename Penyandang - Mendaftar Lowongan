<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Form Pendaftaran Lowongan - KARYA</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap" rel="stylesheet">
    <style>body { font-family: 'Lexend', sans-serif; }</style>
</head>
<body class="bg-gray-50">
    <nav class="bg-white shadow px-6 py-3">
        <a href="penyandang-lowongan.html" class="text-blue-600 hover:underline">← Kembali ke Lowongan</a>
    </nav>
    <div class="max-w-2xl mx-auto px-6 py-12">
        <div class="bg-white p-8 rounded-2xl shadow-md">
            <h1 class="text-2xl font-bold text-blue-900">Pendaftaran Lowongan</h1>
            <p class="text-gray-600 mt-1">Lengkapi data berikut untuk melamar pekerjaan.</p>
            <form id="form" class="mt-6">
                <div class="mb-4">
                    <label class="block font-bold">Nama Lengkap</label>
                    <input type="text" class="w-full p-3 rounded-xl bg-gray-100" value="Budi Santoso" readonly>
                </div>
                <div class="mb-4">
                    <label class="block font-bold">Email</label>
                    <input type="email" class="w-full p-3 rounded-xl bg-gray-100" value="budi@example.com" readonly>
                </div>
                <div class="mb-4">
                    <label class="block font-bold">Lowongan yang Dilamar</label>
                    <input type="text" id="lowongan" class="w-full p-3 rounded-xl bg-gray-100" value="Frontend Developer" readonly>
                </div>
                <div class="mb-4">
                    <label class="block font-bold">Upload CV (PDF)</label>
                    <input type="file" accept=".pdf" class="w-full p-2">
                    <p class="text-xs text-gray-500 mt-1">Maksimal 2MB</p>
                </div>
                <div class="mb-4">
                    <label class="block font-bold">Pesan untuk Perusahaan (opsional)</label>
                    <textarea class="w-full p-3 rounded-xl bg-gray-100" rows="3" placeholder="Tulis pesan singkat..."></textarea>
                </div>
                <button type="submit" class="w-full bg-blue-900 text-white py-3 rounded-xl font-bold hover:bg-blue-800">Kirim Lamaran</button>
            </form>
        </div>
    </div>
    <script>
        // Ambil parameter id dari URL untuk menampilkan judul lowongan (opsional)
        const urlParams = new URLSearchParams(window.location.search);
        const lowonganId = urlParams.get('id');
        if (lowonganId) {
            // Simulasi: bisa gunakan fetch atau data statis
            document.getElementById('lowongan').value = `Lowongan ID ${lowonganId}`;
        }
        document.getElementById('form').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Lamaran berhasil dikirim! Perusahaan akan menghubungi Anda.');
            window.location.href = 'penyandang-lowongan.html';
        });
    </script>
</body>
</html>
