<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - KARYA</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: "#001855",
                        "primary-container": "#002a84",
                        secondary: "#7c5800",
                        "secondary-container": "#feb700",
                        surface: "#fcf9f8",
                        "on-surface": "#1b1c1c",
                        "on-surface-variant": "#43474f",
                    },
                    fontFamily: { sans: ["Lexend"] },
                }
            }
        }
    </script>
</head>
<body class="bg-surface">

    <div class="min-h-screen flex items-center justify-center px-4">
        <div class="bg-white rounded-3xl shadow-lg p-8 max-w-md w-full border border-surface-container-high">
            <div class="text-center mb-8">
                <h1 class="text-3xl font-black text-primary">KARYA</h1>
                <p class="text-on-surface-variant">Masuk ke akun Anda</p>
            </div>
            <form id="loginForm">
                <div class="mb-4">
                    <label class="block text-sm font-bold text-outline mb-1">Email</label>
                    <input type="email" id="email" class="w-full p-3 rounded-xl bg-surface-container-high border border-transparent focus:border-primary" placeholder="nama@email.com" required>
                </div>
                <div class="mb-6">
                    <label class="block text-sm font-bold text-outline mb-1">Kata Sandi</label>
                    <input type="password" id="password" class="w-full p-3 rounded-xl bg-surface-container-high border border-transparent focus:border-primary" placeholder="••••••••" required>
                </div>
                <button type="submit" class="w-full bg-primary text-white py-3 rounded-xl font-bold hover:bg-primary/90">Masuk</button>
            </form>
            <p class="text-center text-sm text-on-surface-variant mt-6">Belum punya akun? <a href="register.html" class="text-primary font-bold">Daftar</a></p>
        </div>
    </div>

    <script>
        document.getElementById('loginForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const email = document.getElementById('email').value;
            // Simulasi redirect berdasarkan role (contoh sederhana)
            if (email.includes('admin')) {
                window.location.href = 'admin-dashboard.html';
            } else if (email.includes('perusahaan')) {
                window.location.href = 'perusahaan-dashboard.html';
            } else {
                window.location.href = 'penyandang-lowongan.html';
            }
        });
    </script>
</body>
</html>